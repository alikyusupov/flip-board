{
  "name": "mpsurf",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "root": "apps/mpsurf",
  "sourceRoot": "apps/mpsurf/src",
  "prefix": "app",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath.base}"],
      "options": {
        "outputPath": "dist/apps/mpsurf",
        "index": "apps/mpsurf/src/index.html",
        "browser": "apps/mpsurf/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/mpsurf/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [{ "glob": "**/*", "input": "apps/mpsurf/public" }],
        "styles": [
          "node_modules/ng-zorro-antd/ng-zorro-antd.min.css",
          "apps/mpsurf/src/styles.scss"
        ],
        "scripts": [],
        "allowedCommonJsDependencies": ["file-saver"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "5000kB",
              "maximumError": "5MB"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kB",
              "maximumError": "8kB"
            }
          ],
          "outputHashing": "all"
        },
        "mock": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "apps/mpsurf/src/environments/environment.ts",
              "with": "apps/mpsurf/src/environments/environment.mock.ts"
            }
          ]
        },
        "dev": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "apps/mpsurf/src/environments/environment.ts",
              "with": "apps/mpsurf/src/environments/environment.dev.ts"
            }
          ]
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": { "buildTarget": "mpsurf:build:production" },
        "mock": { "buildTarget": "mpsurf:build:mock" },
        "dev": { "buildTarget": "mpsurf:build:dev" }
      },
      "defaultConfiguration": "mock"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "mpsurf:build"
      }
    },
    "test": {
      "executor": "@angular/build:karma",
      "options": {
        "polyfills": ["zone.js", "zone.js/testing"],
        "tsConfig": "apps/mpsurf/tsconfig.spec.json",
        "inlineStyleLanguage": "scss",
        "assets": [{ "glob": "**/*", "input": "apps/mpsurf/public" }],
        "styles": [
          "node_modules/ng-zorro-antd/ng-zorro-antd.min.css",
          "apps/mpsurf/src/styles.scss"
        ],
        "scripts": []
      }
    },
    "lint": {
      "executor": "@angular-eslint/builder:lint",
      "options": {
        "lintFilePatterns": ["apps/mpsurf/src/**/*.ts", "apps/mpsurf/src/**/*.html"]
      }
    }
  }
}
